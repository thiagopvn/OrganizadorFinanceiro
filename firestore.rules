rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users - any authenticated user can read profiles (needed to load partner info)
    // Only the owner can write their own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Couple data
    match /couples/{coupleId} {
      // Any authenticated user can read a couple doc (needed for joinCouple flow)
      // They still need to know the coupleId (shared via invite code)
      allow read: if request.auth != null;

      // Only members can write to an existing couple
      allow update: if request.auth != null &&
        request.auth.uid in resource.data.partnerIds;

      // Any authenticated user can create a couple
      allow create: if request.auth != null;

      // Special case: allow a user to add themselves to a couple
      // (joinCouple adds their UID to partnerIds via arrayUnion)
      allow update: if request.auth != null &&
        request.auth.uid in request.resource.data.partnerIds &&
        resource.data.partnerIds.size() < 2;

      // Prevent delete from client (only admins via console)
      allow delete: if false;

      // All subcollections - only couple members can access
      match /transactions/{docId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.partnerIds;
      }

      match /budgets/{docId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.partnerIds;
      }

      match /goals/{docId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.partnerIds;
      }

      match /subscriptions/{docId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.partnerIds;
      }

      match /settlements/{docId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.partnerIds;
      }

      match /cards/{docId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.partnerIds;
      }

      match /investments/{docId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.partnerIds;
      }
    }

    // Notifications - user can only see their own
    match /notifications/{notificationId} {
      allow read, update: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create: if false; // Only Cloud Functions write notifications
    }
  }
}
